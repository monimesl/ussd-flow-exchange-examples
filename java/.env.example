# RSA private key for decrypting Monime USSD exchange requests.
# Paste the full PEM key including -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY----- lines.
# In Vercel, add this as an environment variable in the project settings.
MONIME_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
MIIEvgIBADANBgkqhkiG9w0BAQEFAASC...
-----END PRIVATE KEY-----"

# Server port (default: 3000)
PORT=3000
